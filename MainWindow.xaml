<Window x:Class="ActraNavWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ActraNavWin"
        mc:Ignorable="d"
        Title="ActraNavWin"
        Width="480" Height="800"
        MinWidth="360" MinHeight="640"
        WindowStyle="None"
        Topmost="True"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ========== ヘッダー（常時表示・ドラッグ領域） ========== -->
        <Border x:Name="toolbarBorder"
                Grid.Row="0"
                Background="#4CAF50"
                Padding="10,6"
                MouseLeftButtonDown="Header_MouseDown">
            <StackPanel>
                <!-- 上段: 状態 + 接続先 + モード -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="stateDot"
                             Width="12" Height="12"
                             Fill="#FFC107"
                             VerticalAlignment="Center" />

                    <TextBlock Grid.Column="2"
                               x:Name="txtQrInfo"
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center" />

                    <ComboBox Grid.Column="4"
                              x:Name="cmbUrl"
                              MinWidth="120"
                              VerticalAlignment="Center"
                              SelectionChanged="CmbUrl_SelectionChanged" />
                </Grid>

                <!-- 下段: ユーザー + 操作 -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="txtUser"
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="2"
                            x:Name="btnResetConfig"
                            Content="&#x2699;"
                            FontSize="14"
                            Width="32" Height="28"
                            Padding="0"
                            ToolTip="設定画面に戻る"
                            Click="BtnResetConfig_Click" />

                    <Button Grid.Column="4"
                            x:Name="btnLogout"
                            Content="ログアウト"
                            Padding="12,4"
                            Click="BtnLogout_Click" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== コンテンツ領域 ========== -->
        <Grid Grid.Row="1">
            <!-- ========== QrSetupView ========== -->
            <Grid x:Name="QrSetupView" Background="White" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="320">
                    <TextBlock Text="ActraNavWin"
                               FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />

                    <TextBlock Text="初期設定"
                               FontSize="14"
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24" />

                    <TextBlock Text="QR設定JSON"
                               FontSize="13"
                               Margin="0,0,0,4" />

                    <TextBox x:Name="txtQrJson"
                             FontSize="13"
                             FontFamily="Consolas"
                             Padding="8,6"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />

                    <Button x:Name="btnQrApply"
                            Content="設定する"
                            Height="40"
                            FontSize="14"
                            Margin="0,16,0,0"
                            Click="BtnQrApply_Click" />

                    <TextBlock x:Name="txtQrError"
                               Foreground="#C62828"
                               FontSize="12"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />

                    <Button x:Name="btnQrBack"
                            Content="戻る"
                            Height="34"
                            FontSize="13"
                            Margin="0,12,0,0"
                            Background="Transparent"
                            Click="BtnQrBack_Click"
                            Visibility="Collapsed" />
                </StackPanel>
            </Grid>

            <!-- ========== LoginView ========== -->
            <Grid x:Name="LoginView" Background="White" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="280">
                    <TextBlock Text="ActraNavWin"
                               FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />

                    <TextBlock x:Name="txtLoginConnInfo"
                               FontSize="11"
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24" />

                    <TextBlock Text="社員番号"
                               FontSize="13"
                               Margin="0,0,0,4" />

                    <TextBox x:Name="txtStaffCode"
                             FontSize="16"
                             Padding="8,6"
                             MaxLength="20"
                             KeyDown="TxtStaffCode_KeyDown" />

                    <Button x:Name="btnLogin"
                            Content="ログイン"
                            Height="40"
                            FontSize="14"
                            Margin="0,20,0,0"
                            Click="BtnLogin_Click"
                            IsDefault="True" />

                    <TextBlock x:Name="txtLoginError"
                               Foreground="#C62828"
                               FontSize="12"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>

            <!-- ========== MainView ========== -->
            <Grid x:Name="MainView" Visibility="Collapsed">
                <!-- WebView2 は C# から動的に追加 -->
                <Border x:Name="webViewHost" Background="White" />
            </Grid>
        </Grid>
    </Grid>
</Window>
